# ========= Server Config =========
PORT=3000
NODE_ENV=development
API_PREFIX=api/v1

# ========= Database (MySQL) =========
DATABASE_URL="mysql://root:yourpassword@localhost:3306/niletech_db"

# ========= JWT Config =========
JWT_SECRET=superstrongsecret123
JWT_EXPIRES_IN=15m

REFRESH_TOKEN_SECRET=anothersecret456
REFRESH_TOKEN_EXPIRES_IN=7d

# ========= WebSocket Config =========
WS_PORT=3001
WS_ORIGIN=http://localhost:3000

# ========= Swagger Docs =========
SWAGGER_TITLE=NileTech API
SWAGGER_DESCRIPTION=API docs for NileTech backend
SWAGGER_VERSION=1.0

# ========= Logging & Debugging =========
LOG_LEVEL=debug
SENTRY_DSN=   # Optional: Add if you're using Sentry

# ========= Email (Optional, for future) =========
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_user
SMTP_PASS=your_pass
EMAIL_FROM=noreply@niletech.com
